# ============================================================
# AI Blogger Automation Platform — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --------------------------
# Application
# --------------------------
APP_NAME="AI Blogger Automation Platform"
APP_ENV=development              # development | staging | production
APP_DEBUG=true
APP_SECRET_KEY=your-secret-key-here-change-in-production
APP_LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR

# --------------------------
# Database (PostgreSQL)
# --------------------------
DATABASE_URL=postgresql+asyncpg://blogger_user:blogger_pass@localhost:5432/ai_blogger
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# --------------------------
# Cache & Task Queue (Redis)
# --------------------------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --------------------------
# LLM Providers
# --------------------------

# Google Gemini (Primary — Recommended)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-pro
GEMINI_TEMPERATURE=0.7

# OpenAI (Fallback)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.7

# Anthropic Claude (Optional)
ANTHROPIC_API_KEY=your-anthropic-api-key
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# Groq (Optional — fast & cheap for quick tasks)
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.1-70b-versatile

# Default LLM provider selection per module
# Options: gemini | openai | claude | groq
LLM_DEFAULT_PROVIDER=gemini
LLM_CONTENT_PROVIDER=gemini
LLM_MARKET_ANALYSIS_PROVIDER=gemini
LLM_KEYWORD_PROVIDER=gemini
LLM_SOCIAL_PROVIDER=gemini

# Cost limits (USD) per pipeline run — 0 = unlimited
LLM_MAX_COST_PER_RUN=0.50

# --------------------------
# Google APIs
# --------------------------

# Blogger API (OAuth 2.0)
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback
GOOGLE_SCOPES=https://www.googleapis.com/auth/blogger

# Google Search Console API
SEARCH_CONSOLE_SITE_URL=https://varatharajan0180.blogspot.com/

# Google Analytics 4
GA4_PROPERTY_ID=your-ga4-property-id
GA4_CREDENTIALS_PATH=./credentials/ga4-service-account.json

# --------------------------
# Trend Research
# --------------------------

# NewsAPI (https://newsapi.org/)
NEWS_API_KEY=your-newsapi-key

# RSS Feeds (comma-separated)
RSS_FEED_URLS=https://feeds.feedburner.com/TechCrunch,https://www.infoq.com/feed/,https://hnrss.org/frontpage

# Google Trends (Pytrends — no API key required, uses scraping)
PYTRENDS_TIMEOUT=30
PYTRENDS_RETRIES=3

# --------------------------
# Image Sources
# --------------------------

# Unsplash (https://unsplash.com/developers)
UNSPLASH_ACCESS_KEY=your-unsplash-access-key

# Pexels (https://www.pexels.com/api/)
PEXELS_API_KEY=your-pexels-api-key

# AI Image Generation — Google Imagen (optional)
IMAGEN_API_KEY=your-imagen-api-key
IMAGEN_MODEL=imagen-3.0-fast-generate-001

# --------------------------
# Blog Targets
# --------------------------

# Primary blog (Blogger)
PRIMARY_BLOG_ID=your-blogger-blog-id
PRIMARY_BLOG_URL=https://varatharajan0180.blogspot.com/

# --------------------------
# Pipeline Configuration
# --------------------------

# Daily automation schedule (CRON format, UTC)
PIPELINE_CRON_SCHEDULE="0 0 * * *"     # Daily at 00:30 UTC (06:00 AM IST)

# Pipeline behavior
PIPELINE_POSTS_PER_RUN=1               # How many posts to generate per daily run
PIPELINE_SEO_MIN_SCORE=80              # Minimum SEO score to auto-publish (0-100)
PIPELINE_MAX_REFINEMENT_ITERATIONS=2   # Max AI refinement loops per post
PIPELINE_HUMAN_APPROVAL_REQUIRED=false # true = queue for review; false = auto-publish

# Content settings
CONTENT_MIN_WORD_COUNT=1200
CONTENT_MAX_WORD_COUNT=2500
CONTENT_LANGUAGE=en

# --------------------------
# Notifications (Optional)
# --------------------------

# Email notifications for pipeline failures
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
NOTIFICATION_EMAIL=admin@yourdomain.com

# Slack webhook (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# --------------------------
# Frontend / API
# --------------------------
API_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
